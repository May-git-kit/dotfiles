# --- Appearance ---
theme = Catppuccin Mocha
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

# Glassmorphism / Transparency
background-opacity = 1.0
background-blur-radius = 20

# Window Decorations
window-decoration = false
window-padding-x = 18
window-padding-y = 10
confirm-close-surface = false

# --- Cursor ---
cursor-style = bar
cursor-style-blink = true
cursor-color = #f5e0dc

# --- Mouse & Selection ---
mouse-hide-while-typing = true
#copy-on-selection = true

# --- Performance ---
# This ensures faster startup by reusing the same GTK instance
gtk-single-instance = true

# --- Keybindings ---
# Mimicking standard terminal splits/tabs
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+j=goto_split:down

# Quick Reload
keybind = ctrl+shift+r=reload_config

# Global Settings
max-history=100
sort=-time

# Appearance
font=Inter 11
width=350
height=150
margin=20
padding=15
border-size=2
border-radius=10
icons=1
max-icon-size=48

# Catppuccin Mocha Colors
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#b4befe
progress-color=over #313244

# Behavior
default-timeout=5000
ignore-timeout=0
layer=overlay
anchor=top-right

[urgency=low]
border-color=#a6e3a1
default-timeout=2000

[urgency=high]
border-color=#f38ba8
default-timeout=0
text-color=#f38ba8

[category=mpd]
default-timeout=2000
group-by=category
